# =============================================================================
# Project5 - Private Email dApp - Environment Configuration
# =============================================================================
# Copy to .env and fill values. NEVER commit .env to version control.
# PREREQUISITE: External ERC-4337 infrastructure must be running (RPC, bundler, paymaster API).
# Usage: docker compose -f infra/docker/docker-compose.yml --env-file .env up -d
# =============================================================================

# -----------------------------------------------------------------------------
# CONTRACT DEPLOYMENT (Hardhat: npm run deploy:localhost from contracts/)
# -----------------------------------------------------------------------------
CONTRACT_RPC_URL=http://host.docker.internal:8545
CONTRACT_CHAIN_ID=137
CONTRACT_DEPLOY_OUTPUT_DIR=
CONTRACT_MAIL_ADDRESS_FILE=
CONTRACT_DEPLOYER_MNEMONIC=test test test test test test test test test test test junk
CONTRACT_DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# FRONTEND - VITE_* (required; no defaults; source of truth for the app)
# -----------------------------------------------------------------------------
# Contract address from deploy-output/mail-address.txt after running deploy
VITE_PRIVATE_MAIL_ADDRESS=
VITE_RPC_URL=http://host.docker.internal:8545
VITE_BUNDLER_URL=http://host.docker.internal:4337
VITE_PAYMASTER_API_URL=http://host.docker.internal:3000
VITE_CHAIN_ID=137
VITE_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
VITE_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
VITE_ANVIL_WHALE_CANDIDATES=0x47c031236e19d024b42f8de678d3110562d925b5,0x794a61358D6845594F94dc1DB02A252b5b4814aD,0xF977814e90dA44bFA03b6295A0616a897441aceC,0x28C6c06298d514Db089934071355E5743bf21d60
VITE_ENABLE_ANVIL_WHALE_FUNDING=true

# -----------------------------------------------------------------------------
# TOOLS - SEND-RECEIVE TEST (tools/send-receive-test; npm run send-receive-test)
# -----------------------------------------------------------------------------
# Uses CONTRACT_DEPLOYER_MNEMONIC above. All below are required.
TOOLS_RPC_URL=http://host.docker.internal:8545
TOOLS_CHAIN_ID=137
TOOLS_MAIL_ADDRESS_FILE=deploy-output/mail-address.txt
TOOLS_MESSAGE=Hello from send-receive test!
TOOLS_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
TOOLS_USDC_FUND_AMOUNT=10
TOOLS_ANVIL_WHALE_CANDIDATES=0x47c031236e19d024b42f8de678d3110562d925b5,0x794a61358D6845594F94dc1DB02A252b5b4814aD,0xF977814e90dA44bFA03b6295A0616a897441aceC,0x28C6c06298d514Db089934071355E5743bf21d60

# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------
VITE_PORT=5173
FRONTEND_PORT=3002
