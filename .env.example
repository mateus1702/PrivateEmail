# =============================================================================
# Project5 - Private Email dApp - Environment Configuration
# =============================================================================
# Copy to .env and fill values. NEVER commit .env to version control.
# PREREQUISITE: External ERC-4337 infrastructure must be running (RPC, bundler, paymaster API).
# Usage: docker compose -f infra/docker/docker-compose.yml --env-file .env up -d
# =============================================================================

# -----------------------------------------------------------------------------
# EXTERNAL AA INFRASTRUCTURE (required - must be running before project5)
# -----------------------------------------------------------------------------
# Chain RPC URL. For Docker: host.docker.internal. For local dev: 127.0.0.1
RPC_URL=http://host.docker.internal:8545
# ERC-4337 bundler URL (Docker: host.docker.internal)
BUNDLER_URL=http://host.docker.internal:4337
# Paymaster API URL (Docker: host.docker.internal)
PAYMASTER_API_URL=http://host.docker.internal:3000
# ERC-4337 EntryPoint v0.7 address
ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Chain ID (137 = Polygon mainnet, 80002 = Polygon Amoy)
CHAIN_ID=137

# -----------------------------------------------------------------------------
# CONTRACT DEPLOYMENT
# -----------------------------------------------------------------------------
# Output directory for deployment artifacts (Docker: /deploy-output)
DEPLOY_OUTPUT_DIR=/deploy-output
# Path where mail contract address is written
MAIL_CONTRACT_ADDRESS_FILE=/deploy-output/mail-address
# Mnemonic for deployer account (used when DEPLOYER_PRIVATE_KEY is empty)
DEPLOYER_MNEMONIC=test test test test test test test test test test test junk
# Private key for deployer (optional; if set, overrides mnemonic)
DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
# Port for frontend dev server (local dev)
VITE_PORT=5173
# Port for frontend in Docker (external)
FRONTEND_PORT=3002
# USDC token address (Polygon USDC default; used for paymaster sponsorship balance)
USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Whale addresses for Anvil dev funding (CSV; first with sufficient balance used)
ANVIL_WHALE_CANDIDATES=0x47c031236e19d024b42f8de678d3110562d925b5,0x794a61358D6845594F94dc1DB02A252b5b4814aD,0xF977814e90dA44bFA03b6295A0616a897441aceC,0x28C6c06298d514Db089934071355E5743bf21d60
# Enable "Load 10 USDC from whale" button when RPC is Anvil (dev only)
ENABLE_ANVIL_WHALE_FUNDING=true
